[user]
    email = 8346874+aous-afk@users.noreply.github.com
    name = Aous Deeb
    signingkey = ~/.ssh/pcarchCommitSign.pub

[gpg]
    format = ssh

[commit]
    gpgsign = true

[init]
    defaultBranch = main

[core]
    pager = delta
    autocrlf = input
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
    editor = nvim

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[rebase]
    autoStash = true

[fetch]
    prune = true

[color]
    ui = auto
    branch = auto
    diff = auto
    status = auto

[status]
    short = true
    branch = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red
    new = cyan

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[merge]
    tool = vimdiff
    conflictstyle = diff3

[mergetool]
    prompt = false
    keepBackup = false

[mergetool "vimdiff"]
    cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[difftool]
    prompt = false

[diff]
    tool = nvimdiff
    algorithm = histogram
    colorMoved = default

[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate --all

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    dark = true
